<view class="container">
  <view class="logo-area">
    <view class="logo-circle"></view>
    <text class="logo-text">天选之饭</text>
    <text class="logo-sub">今天吃什么 · 交给命运</text>
  </view>

  <view class="card form-card">
    <input class="input" placeholder="请输入用户名" bindinput="onUsernameInput" />
    <input class="input" placeholder="请输入密码" password="true" bindinput="onPasswordInput" />
    <button class="button-primary" bindtap="onLogin">登录</button>
    <view class="link-row">
      <text>还没有账号？</text>
      <text class="link" bindtap="goRegister">去注册</text>
    </view>
  </view>
</view>
