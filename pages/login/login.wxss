/* ========== 登录页整体背景：淡紫粉 + 柔和渐变 ========== */
page {
  background: linear-gradient(180deg, #f6f0ff 0, #fdf7ff 45%, #ffe6f4 100%);
}

.container {
  position: relative;
  min-height: 100vh;
  padding: 80rpx 40rpx 60rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  overflow: hidden;
}

/* 背景圆块（淡淡的紫+薄荷） */
.container::before,
.container::after {
  content: "";
  position: absolute;
  border-radius: 50%;
  opacity: 0.4;
  z-index: 0;
}

.container::before {
  width: 280rpx;
  height: 240rpx;
  background: #d8c8ff;
  top: -80rpx;
  right: -80rpx;
}

.container::after {
  width: 240rpx;
  height: 220rpx;
  background: #c9f2ff;
  bottom: -80rpx;
  left: -60rpx;
}

/* ========== 顶部Logo区域：更可爱、俏皮 ========== */
.logo-area {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

/* 背后的粉紫圆形（当头像标志） */
.logo-circle {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 30% 30%, #ffeaf7 0, #ff9ac6 55%, #f36aff 100%);
  box-shadow: 0 14rpx 30rpx rgba(243, 106, 255, 0.45);
  position: relative;
  margin-bottom: 20rpx;
}

/* 圆形里面放个小表情（用伪元素画一个笑脸） */
.logo-circle::before {
  content: "😋";
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 58rpx;
}

/* 标题字体：粉紫渐变 + 字距 + 阴影 */
.logo-text {
  font-size: 40rpx;
  font-weight: 800;
  letter-spacing: 6rpx;
  margin-bottom: 6rpx;
  background-image: linear-gradient(90deg, #ff6b9c, #a86bff);
  -webkit-background-clip: text;
  color: transparent;
  text-shadow: 0 4rpx 10rpx rgba(168, 107, 255, 0.35);
  font-family: "PingFang SC", "Helvetica Neue", sans-serif;
}

/* 副标题：更俏皮一点，小一点、浅一点 */
.logo-sub {
  font-size: 24rpx;
  color: #b38aff;
  opacity: 0.9;
  margin-top: 4rpx;
}

/* ========== 表单卡片：淡紫花纹边框 ========== */
.card.form-card {
  position: relative;
  z-index: 2;
  width: 100%;
  margin-top: 10rpx;
  border-radius: 26rpx;
  padding: 28rpx 26rpx 26rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.98);
  backdrop-filter: blur(8rpx);
}

/* 渐变边框效果 */
.card.form-card::before {
  content: "";
  position: absolute;
  inset: -6rpx;
  border-radius: inherit;
  background: conic-gradient(
    from 150deg,
    #c3b5ff,
    #ffb3d1,
    #ffe29f,
    #c3f3ff,
    #c3b5ff
  );
  z-index: -2;
  animation: loginBorderRotate 8s linear infinite;
}

.card.form-card::after {
  content: "";
  position: absolute;
  inset: 4rpx;
  border-radius: inherit;
  background:
    radial-gradient(circle at 0% 0%, rgba(255,255,255,0.98) 0, rgba(255,255,255,0) 55%),
    radial-gradient(circle at 100% 100%, rgba(236,230,255,0.96) 0, rgba(236,230,255,0) 68%),
    rgba(255,255,255,0.99);
  z-index: -1;
}

@keyframes loginBorderRotate {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}

/* 卡片浮动一点点 */
.card.form-card {
  animation: loginCardZoomIn 0.6s ease-out;
}

@keyframes loginCardZoomIn {
  0% {
    opacity: 0;
    transform: scale(0.9) translateY(20rpx);
  }
  100% {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
}

/* ========== 输入框：软糯圆角 ========== */
.input {
  width: 100%;
  box-sizing: border-box;

  /* 原来是 padding: 16rpx 22rpx; 文字有点靠上 */
  height: 80rpx;
  line-height: 80rpx;   /* 让文字垂直居中 */
  padding: 0 26rpx;

  margin-bottom: 20rpx;
  border-radius: 999rpx;
  background: #f7f1ff;
  font-size: 26rpx;
  color: #664f99;
}

/* placeholder 默认样式就行，不额外改 */

/* ========== 登录按钮：紫+薄荷渐变，带一点弹性 ========== */
.button-primary {
  width: 100%;
  margin-top: 4rpx;
  padding: 18rpx 0;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #7e69ff, #ff6b9c);
  color: #ffffff;
  font-size: 30rpx;
  box-shadow: 0 10rpx 20rpx rgba(126, 105, 255, 0.35);
  position: relative;
  overflow: hidden;
}

/* 轻微扫光 */
.button-primary::before {
  content: "";
  position: absolute;
  inset: -40%;
  background: linear-gradient(
    120deg,
    rgba(255,255,255,0),
    rgba(255,255,255,0.9),
    rgba(255,255,255,0)
  );
  transform: translateX(-120%) skewX(-15deg);
  opacity: 0;
  animation: loginBtnShine 3s infinite;
}

@keyframes loginBtnShine {
  0% {
    opacity: 0;
    transform: translateX(-120%) skewX(-15deg);
  }
  40% {
    opacity: 1;
    transform: translateX(0%) skewX(-15deg);
  }
  70% {
    opacity: 0;
    transform: translateX(80%) skewX(-15deg);
  }
  100% {
    opacity: 0;
    transform: translateX(80%) skewX(-15deg);
  }
}

/* 按下时Q弹一点 */
.button-primary:active {
  transform: scale(0.95) translateY(2rpx);
}

/* ========== 注册链接区域 ========== */
.link-row {
  margin-top: 20rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 24rpx;
  color: #a18ccc;
}

.link-row text {
  margin: 0 2rpx;
}

/* “去注册”用粉紫色突出一点 */
.link {
  color: #ff6b9c;
}
