.index-page {
  position: relative;
  min-height: 100vh;
  padding: 40rpx 32rpx 80rpx;
}
.bg-circle {
  position: absolute;
  border-radius: 50%;
  opacity: 0.25;
  filter: blur(2rpx);
  z-index: -1;
}
.bg1 {
  width: 260rpx;
  height: 260rpx;
  top: 40rpx;
  right: -60rpx;
  background: radial-gradient(circle at 30% 30%, #ffffff, #ff9a9e);
  animation: float 10s ease-in-out infinite alternate;
}
.bg2 {
  width: 220rpx;
  height: 220rpx;
  bottom: 120rpx;
  left: -40rpx;
  background: radial-gradient(circle at 30% 30%, #ffffff, #fecf6a);
  animation: float 12s ease-in-out infinite alternate-reverse;
}
.bg3 {
  width: 180rpx;
  height: 180rpx;
  top: 260rpx;
  left: 160rpx;
  background: radial-gradient(circle at 30% 30%, #ffffff, #ffecd2);
  animation: float 14s ease-in-out infinite alternate;
}
.weather-card {
  display: flex;
  padding: 26rpx 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 20rpx 40rpx rgba(255, 163, 158, 0.25);
  margin-bottom: 28rpx;
}
.weather-left {
  flex: 1;
}
.weather-title {
  font-size: 24rpx;
  color: #ff9a9e;
}
.weather-main {
  display: block;
  margin-top: 4rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}
.weather-suggestion {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #777777;
}
.main-card {
  margin-top: 12rpx;
  padding: 32rpx 28rpx 36rpx;
  background: rgba(255, 255, 255, 0.96);
  border-radius: 32rpx;
  box-shadow: 0 24rpx 60rpx rgba(255, 158, 131, 0.25);
}
.hero-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
}
.hero-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333333;
}
.hero-sub {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #888888;
}
.hero-badge {
  padding: 14rpx 22rpx;
  border-radius: 999px;
  background: linear-gradient(135deg, #ffecd2, #fcb69f);
}
.badge-text {
  font-size: 24rpx;
  color: #aa4a44;
}
.category-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
}
.cat-chip {
  flex: 1;
  margin: 0 8rpx;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 999px;
  font-size: 26rpx;
  background: #f7f7f7;
  color: #777777;
}
.cat-chip.active {
  background: linear-gradient(135deg, #ff9a9e, #fecf6a);
  color: #ffffff;
  box-shadow: 0 12rpx 24rpx rgba(255, 138, 128, 0.35);
  transform: translateY(-4rpx);
}
.result-card {
  margin-top: 4rpx;
  padding: 26rpx 22rpx;
  border-radius: 26rpx;
  background: #fff7f2;
  border: 1rpx solid rgba(255, 170, 140, 0.35);
}
.result-label {
  font-size: 24rpx;
  color: #ff9a9e;
}
.result-name {
  display: block;
  margin-top: 12rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: #333333;
}
.result-tag {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #ff8666;
}
.primary-btn {
  margin-top: 26rpx;
  width: 100%;
  border-radius: 999px;
  padding: 22rpx 0;
  font-size: 30rpx;
  color: #ffffff;
  border: none;
  background: linear-gradient(135deg, #ff9a9e, #fecf6a);
  box-shadow: 0 20rpx 40rpx rgba(255, 138, 128, 0.4);
}
.actions-row {
  display: flex;
  justify-content: space-between;
  margin-top: 18rpx;
}
.secondary-btn {
  flex: 1;
  margin: 0 6rpx;
  border-radius: 999px;
  padding: 12rpx 0;
  font-size: 26rpx;
  background: #ffffff;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
}
@keyframes float {
  from { transform: translate3d(0, 0, 0); }
  to   { transform: translate3d(0, -30rpx, 0); }
}
