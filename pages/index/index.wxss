/* ================== 页面背景 ================== */
.index-page {
  position: relative;
  width: 100%;
  min-height: 100vh;
  background: linear-gradient(180deg, #ffe6f2 0%, #ffeef7 100%);
  overflow-x: hidden;
  padding-bottom: 60rpx;
}


/* ================== 背景动态圆圈 ================== */
.bg-circle {
  position: absolute;
  border-radius: 50%;
  opacity: 0.45;
  animation: floatCircle 6s ease-in-out infinite alternate;
}

.bg1 {
  width: 260rpx;
  height: 260rpx;
  background: #ffd1e8;
  top: 60rpx;
  left: -80rpx;
  animation-delay: 0s;
}

.bg2 {
  width: 300rpx;
  height: 300rpx;
  background: #ffc4d8;
  top: 480rpx;
  right: -120rpx;
  animation-delay: 1s;
}

.bg3 {
  width: 200rpx;
  height: 200rpx;
  background: #ffe2f0;
  top: 780rpx;
  left: 40rpx;
  animation-delay: 2s;
}

@keyframes floatCircle {
  0%   { transform: translateY(0); }
  100% { transform: translateY(-40rpx); }
}


/* ================== 漂浮爱心 / 糖果图标 ================== */
.floating-icon {
  position: absolute;
  z-index: 1;
  font-size: 44rpx;
  opacity: 0.65;
  animation: floatUp 10s linear infinite;
  filter: drop-shadow(0 4rpx 8rpx rgba(255, 122, 178, 0.45));
}

.i1 { left: 12%; bottom: 10%; animation-delay: 0s; }
.i2 { right: 18%; bottom: 20%; animation-delay: 2.5s; }
.i3 {
  left: 55%;
  bottom: 6%;
  transform: translateX(-50%);
  animation-delay: 4.5s;
}

@keyframes floatUp {
  0%   { transform: translate(-10rpx, 40rpx) scale(0.9); opacity: 0; }
  20%  { opacity: 0.8; }
  80%  { transform: translate(10rpx, -150rpx) scale(1.05); opacity: 0.8; }
  100% { transform: translate(20rpx, -220rpx) scale(1.1); opacity: 0; }
}


/* ================== 漂浮樱花瓣 ================== */
.sakura {
  position: absolute;
  z-index: 0;
  width: 26rpx;
  height: 18rpx;
  background: radial-gradient(circle at 30% 30%, #ffeef7 0, #ff9ac6 60%, #ff6b99 100%);
  border-radius: 60% 40% 60% 40%;
  opacity: 0.75;
  filter: blur(0.5rpx);
  animation: sakuraFall 9s linear infinite;
}

/* 你可以在 WXML 里放 3~4 片樱花，分别用这些类 */
.s1 { left: 8%;  top: -40rpx;  animation-delay: 0s; }
.s2 { left: 40%; top: -80rpx;  animation-delay: 2s; }
.s3 { right: 10%; top: -60rpx; animation-delay: 4s; }
.s4 { right: 30%; top: -100rpx; animation-delay: 1s; }

@keyframes sakuraFall {
  0% {
    transform: translate(0, -40rpx) rotate(0deg);
    opacity: 0;
  }
  15% {
    opacity: 0.9;
  }
  50% {
    transform: translate(-40rpx, 420rpx) rotate(40deg);
  }
  100% {
    transform: translate(40rpx, 900rpx) rotate(120deg);
    opacity: 0;
  }
}


/* ================== 动态渐变流动边框卡片 ================== */
.card {
  margin: 40rpx;
  padding: 32rpx;
  border-radius: 26rpx;
  position: relative;
}

.card-fancy {
  position: relative;
  overflow: hidden;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(12rpx);
}

/* 流动渐变边框 */
.card-fancy::before {
  content: "";
  position: absolute;
  inset: -6rpx;
  border-radius: inherit;
  background: conic-gradient(
    from 180deg,
    #ff9ac6,
    #ffe29f,
    #b5fffc,
    #ffb3d1,
    #ff9ac6
  );
  z-index: -2;
  animation: borderRotate 6s linear infinite;
}

/* 内部白底 + 光晕 */
.card-fancy::after {
  content: "";
  position: absolute;
  inset: 4rpx;
  border-radius: inherit;
  background:
    radial-gradient(circle at 10% 0%, rgba(255,255,255,0.96) 0, rgba(255,255,255,0) 60%),
    radial-gradient(circle at 100% 100%, rgba(255,214,240,0.95) 0, rgba(255,214,240,0) 75%),
    rgba(255,255,255,0.96);
  z-index: -1;
}

.card-fancy-inner {
  position: relative;
  z-index: 10;
}

.card-fancy-animate {
  animation: cardFloat 3.6s ease-in-out infinite;
}

@keyframes borderRotate {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}

@keyframes cardFloat {
  0%   { transform: translateY(0) scale(1); }
  50%  { transform: translateY(-8rpx) scale(1.01); }
  100% { transform: translateY(0) scale(1); }
}


/* ============ 卡片“翻牌”动画（页面打开时） ============ */
@keyframes cardFlipIn {
  0% {
    opacity: 0;
    transform: rotateY(90deg) translateY(20rpx);
  }
  60% {
    opacity: 1;
    transform: rotateY(-8deg) translateY(0);
  }
  100% {
    opacity: 1;
    transform: rotateY(0deg) translateY(0);
  }
}

/* 给天气卡 / 主卡片加翻牌效果（不需要改 WXML） */
.weather-card {
  padding: 40rpx;
  transform-origin: center top;
  animation: cardFlipIn 0.8s ease-out;
}

.main-card {
  transform-origin: center top;
  animation: cardFlipIn 0.8s ease-out 0.12s;
}


/* ================== 天气区域 ================== */
.weather-title {
  font-size: 28rpx;
  color: #ff6b99;
}

.weather-main {
  margin-top: 10rpx;
  font-size: 38rpx;
  font-weight: bold;
  color: #ff4f7d;
}

.weather-suggestion {
  margin-top: 10rpx;
  font-size: 28rpx;
  color: #777;
}


/* ================== 主卡片：抽一抽 ================== */

.hero-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.hero-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff5685;
}

.hero-sub {
  font-size: 26rpx;
  color: #999;
  margin-top: 6rpx;
}

.hero-badge {
  background: #ff89b5;
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
}

.badge-text {
  font-size: 26rpx;
  color: white;
}


/* 分类切换按钮 */
.category-row {
  margin-top: 30rpx;
  display: flex;
  justify-content: space-between;
}

.cat-chip {
  padding: 14rpx 30rpx;
  border-radius: 999rpx;
  background: #ffe6f2;
  color: #ff6b99;
  font-size: 28rpx;
  transition: 0.2s;
}

.cat-chip.active {
  background: #ff6b99;
  color: white;
  transform: scale(1.08);
}


/* ============ 抽取结果卡（从下滑出） ============ */
.result-card {
  margin-top: 36rpx;
  padding: 24rpx;
  text-align: center;
  /* 初始轻微在下方 + 透明 */
  transform: translateY(26rpx);
  opacity: 0;
  animation: resultSlideUp 0.55s ease-out forwards;
}

@keyframes resultSlideUp {
  0% {
    transform: translateY(40rpx);
    opacity: 0;
  }
  100% {
    transform: translateY(0);
    opacity: 1;
  }
}

.result-label {
  color: #ff6b99;
  font-size: 26rpx;
}

.result-name {
  margin-top: 12rpx;
  font-size: 40rpx;
  font-weight: bold;
  color: #ff3b77;
}

.result-tag {
  margin-top: 6rpx;
  color: #777;
  font-size: 26rpx;
}


/* ================== 抽一抽按钮（扫光 + 粒子爆炸） ================== */
.primary-btn {
  margin-top: 40rpx;
  background: linear-gradient(90deg, #ff8bb0, #ff6b99);
  color: white;
  border-radius: 999rpx;
  font-size: 34rpx;
  padding: 20rpx 0;
  transform: translateZ(0);
  position: relative;
  overflow: hidden;
}

/* 扫光：从左到右划过 */
.primary-btn::before {
  content: "";
  position: absolute;
  inset: -40%;
  background: linear-gradient(
    120deg,
    rgba(255,255,255,0),
    rgba(255,255,255,0.9),
    rgba(255,255,255,0)
  );
  transform: translateX(-120%) skewX(-15deg);
  opacity: 0;
  animation: btnShine 3.2s infinite;
}

/* 粒子爆炸：用 box-shadow 模拟多颗小光点往外散开 */
.primary-btn::after {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: inherit;
  opacity: 0;
  pointer-events: none;
  animation: particleBurst 2.6s ease-out infinite;
  animation-delay: 0.8s;
}

@keyframes btnShine {
  0% {
    opacity: 0;
    transform: translateX(-120%) skewX(-15deg);
  }
  40% {
    opacity: 1;
    transform: translateX(10%) skewX(-15deg);
  }
  60% {
    opacity: 0;
    transform: translateX(80%) skewX(-15deg);
  }
  100% {
    opacity: 0;
    transform: translateX(80%) skewX(-15deg);
  }
}

/* 一次爆炸里，几个方向的光点一起飞出去再消失 */
@keyframes particleBurst {
  0% {
    opacity: 0;
    box-shadow:
      0 0 0rpx rgba(255,255,255,0.0),
      0 0 0rpx rgba(255,255,255,0.0),
      0 0 0rpx rgba(255,255,255,0.0),
      0 0 0rpx rgba(255,255,255,0.0);
  }
  20% {
    opacity: 1;
    box-shadow:
      0 -4rpx 0rpx rgba(255,255,255,0.9),
      -6rpx -2rpx 0rpx rgba(255,255,255,0.9),
      6rpx -2rpx 0rpx rgba(255,255,255,0.9),
      0 0 0rpx rgba(255,255,255,0.7);
  }
  60% {
    opacity: 0.8;
    box-shadow:
      0 -30rpx 0rpx rgba(255,255,255,0.0),
      -40rpx -26rpx 0rpx rgba(255,255,255,0.0),
      40rpx -26rpx 0rpx rgba(255,255,255,0.0),
      0 -10rpx 0rpx rgba(255,255,255,0.0);
  }
  100% {
    opacity: 0;
    box-shadow:
      0 -40rpx 0rpx rgba(255,255,255,0.0),
      -60rpx -36rpx 0rpx rgba(255,255,255,0.0),
      60rpx -36rpx 0rpx rgba(255,255,255,0.0),
      0 -20rpx 0rpx rgba(255,255,255,0.0);
  }
}

/* 按压 Q 弹 */
.primary-btn:active {
  transform: scale(0.94);
}


/* ================== 底部两个次级按钮 ================== */
.actions-row {
  margin-top: 20rpx;
  display: flex;
  justify-content: space-between;
}

.secondary-btn {
  width: 45%;
  padding: 18rpx 0;
  border-radius: 999rpx;
  background: white;
  border: 2rpx solid #ff6b99;
  color: #ff6b99;
  font-size: 28rpx;
  transition: 0.2s;
}

.secondary-btn:active {
  transform: scale(0.95);
}
