/* ================== 全局背景 ================== */
page {
  background: linear-gradient(180deg, #ffe8f3, #fff3fb, #ffe8f1);
  font-family: "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei",
    -apple-system, BlinkMacSystemFont, sans-serif;
}

.container {
  position: relative;
  padding: 32rpx 26rpx 40rpx;
  padding-bottom: 140rpx;
  box-sizing: border-box;
}

/* ================== 悬浮猫猫 + 云朵 + 爱心粒子 ================== */
.floating-all {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 9999; /* 整个页面最高层 */
}

/* 三只小猫（不会遮挡输入框） */
.float-cat {
  position: absolute;
  font-size: 60rpx;
  opacity: 0.9;
  animation: catFloat 5.5s ease-in-out infinite;
  text-shadow: 0 6rpx 12rpx rgba(255, 140, 170, 0.35);
}
.cat-a { top: 80rpx; left: 40rpx; }
.cat-b { top: 340rpx; right: 30rpx; animation-delay: 1s; }
.cat-c { top: 600rpx; left: 60rpx; animation-delay: 2s; }

/* 云朵 */
.float-cloud {
  position: absolute;
  width: 160rpx;
  height: 70rpx;
  background: #fff0fb;
  border-radius: 80rpx;
  box-shadow: 0 6rpx 14rpx rgba(255, 140, 170, 0.25);
  opacity: 0.6;
  animation: cloudMove 9s linear infinite;
}
.cloud-1 { top: 480rpx; left: 20rpx; }
.cloud-2 { top: 720rpx; right: 30rpx; animation-delay: 1s; }

/* 爱心粒子 */
.heart-particles {
  position: absolute;
  inset: 0;
}
.heart {
  position: absolute;
  font-size: 28rpx;
  color: #ff8cbf;
  opacity: 0.4;
  animation: heartRise 6s linear infinite;
}
.h1 { left: 15%; bottom: 20%; animation-delay: 0s; }
.h2 { left: 35%; bottom: 25%; animation-delay: 1s; }
.h3 { left: 55%; bottom: 15%; animation-delay: 2s; }
.h4 { left: 75%; bottom: 30%; animation-delay: 3s; }
.h5 { left: 50%; bottom: 10%; animation-delay: 4s; }

/* ================== 卡片（猫爪边框 + 藤蔓） ================== */
.card {
  position: relative;
  z-index: 10;
  padding: 32rpx 26rpx;
  border-radius: 30rpx;
  margin-bottom: 36rpx;
  background: rgba(255, 255, 255, 0.88);
  overflow: hidden;
}

/* 外层旋转渐变边框 */
.card::before {
  content: "";
  position: absolute;
  inset: -5rpx;
  border-radius: inherit;
  background: conic-gradient(
    from 45deg,
    #ffb3cf,
    #ffe29f,
    #ffd6f2,
    #ff8fb8,
    #ffb3cf
  );
  animation: borderSpin 14s linear infinite;
  z-index: -2;
}

/* 内层藤蔓模糊背景 */
.card::after {
  content: "";
  position: absolute;
  inset: 4rpx;
  border-radius: inherit;
  background:
    repeating-linear-gradient(
      135deg,
      rgba(178, 225, 190, 0.35) 0,
      rgba(178, 225, 190, 0.35) 2rpx,
      transparent 2rpx,
      transparent 10rpx
    ),
    rgba(255, 255, 255, 0.92);
  z-index: -1;
}

/* ================== 标题 ================== */
.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #ff5a8f;
  margin-bottom: 20rpx;
}
.section-title::before {
  content: "🐾";
  margin-right: 10rpx;
}

/* ================== 表单 ================== */
.row { margin-bottom: 12rpx; }

.label {
  font-size: 28rpx;
  color: #ff6fa3;
  margin-bottom: 4rpx;
  padding-left: 42rpx;
  position: relative;
}

/* 输入框都增高避免遮挡 */
.input-wrapper { margin-bottom: 24rpx; }

.input {
  width: 100%;
  padding: 24rpx 30rpx;
  border-radius: 25rpx;
  background: #ffffff;
  font-size: 30rpx;
  border: 2rpx solid #ffd7e8;
  box-shadow: 0 8rpx 18rpx rgba(255, 160, 180, 0.22);
  color: #333;
}

/* 左侧图标（按行分类） */
.row-name .label::before { content: "🍜"; left: 0; position: absolute; top: 50%; transform: translateY(-50%); }
.row-tag .label::before { content: "💗"; left: 0; position: absolute; top: 50%; transform: translateY(-50%); }
.row-calorie .label::before { content: "🔥"; left: 0; position: absolute; top: 50%; transform: translateY(-50%); }
.row-advantage .label::before { content: "👍"; left: 0; position: absolute; top: 50%; transform: translateY(-50%); }
.row-disadvantage .label::before { content: "⚠"; left: 0; position: absolute; top: 50%; transform: translateY(-50%); }
.row-address .label::before { content: "📍"; left: 0; position: absolute; top: 50%; transform: translateY(-50%); }

/* 分类选项 pill 按钮 */
.pill-group { display: flex; flex-wrap: wrap; }
.pill {
  padding: 12rpx 28rpx;
  background: #ffe8f3;
  border-radius: 999rpx;
  color: #ff74a7;
  font-size: 26rpx;
  margin-right: 16rpx;
  margin-bottom: 12rpx;
}
.pill.on {
  background: linear-gradient(90deg, #ff8fc4, #ff6ba2);
  color: #fff;
  box-shadow: 0 6rpx 14rpx rgba(255, 90, 160, 0.35);
}

/* 保存按钮 = 猫爪点击动画 */
.btn-primary {
  width: 100%;
  padding: 22rpx 0;
  margin-top: 6rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #ff8bbf, #ff6b9c);
  color: #fff;
  font-size: 32rpx;
  position: relative;
  overflow: hidden;
}

/* 小猫爪装饰 */
.btn-primary::before {
  content: "🐾";
  font-size: 34rpx;
  position: absolute;
  right: 40rpx;
  top: 50%;
  transform: translateY(-50%);
}

.btn-primary:active {
  transform: scale(0.96);
  box-shadow: 0 6rpx 14rpx rgba(255, 110, 155, 0.4);
}

/* ================== 列表 ================== */
.pool-item {
  padding: 20rpx 8rpx;
  border-bottom: 1rpx dashed #ffcee2;
  position: relative;
}

.pool-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.pool-tag { font-size: 24rpx; color: #999; margin-top: 4rpx; }

.pool-meta { font-size: 22rpx; color: #c9a3b8; margin-top: 4rpx; }

.pool-actions { margin-left: 10rpx; display: flex; }

/* 猫爪点击按钮 */
.btn-edit,
.btn-delete {
  padding: 10rpx 26rpx;
  margin-left: 12rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  transition: 0.2s;
}

.btn-edit {
  background: #fff1fb;
  color: #ff6ba2;
  border: 2rpx solid #ffb8d2;
}

.btn-delete {
  background: #ffe7ed;
  color: #ff4f7d;
  border: 2rpx solid #ff9fb9;
}

.btn-edit:active,
.btn-delete:active {
  transform: scale(0.92);
}

/* 行内飘动爱心 */
.row-heart {
  position: absolute;
  right: 50rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 22rpx;
  color: #ff9ec3;
  opacity: 0.4;
  animation: littleHeart 4s ease-in-out infinite;
}

/* ================== 动画 ================== */
@keyframes catFloat {
  0% { transform: translateY(0); }
  50% { transform: translateY(-14rpx); }
  100% { transform: translateY(0); }
}

@keyframes cloudMove {
  0% { transform: translateX(0); }
  50% { transform: translateX(-18rpx); }
  100% { transform: translateX(0); }
}

@keyframes heartRise {
  0% { transform: translateY(0) scale(0.5); opacity: 0.5; }
  100% { transform: translateY(-90rpx) scale(1.2); opacity: 0; }
}

@keyframes littleHeart {
  0% { transform: translateY(-10rpx) scale(1); }
  50% { transform: translateY(-20rpx) scale(1.2); }
  100% { transform: translateY(-10rpx) scale(1); }
}

@keyframes borderSpin {
  0% { transform: rotate(0); }
  100% { transform: rotate(360deg); }
}
