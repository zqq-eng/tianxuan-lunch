<!-- pages/community/community.wxml -->
<view class="container">
  <!-- 顶部漂浮小图标 -->
  <view class="floating-icon-comm fi1">🍱</view>
  <view class="floating-icon-comm fi2">✨</view>

  <!-- 发帖卡片 -->
  <view class="card">
    <view class="title">发布一条今日吃饭记录</view>
    <textarea
      class="textarea"
      placeholder="例如：中午黄焖鸡+烤地瓜，吃得很满足但也比较健康~"
      value="{{content}}"
      bindinput="onContentInput"
    />
    <button class="button-primary" bindtap="onPost">发布</button>
    <view class="tip">
      当前为本地模式：只有本机能看到这些记录，适合自己记饮食。
    </view>
  </view>

  <!-- 我的记录卡片 -->
  <view class="card">
    <view class="title">我的饮食记录</view>
    <block wx:for="{{posts}}" wx:key="id">
      <view class="post">
        <view class="post-header">
          <text class="time">{{item.timeStr}}</text>
        </view>
        <text class="body">{{item.content}}</text>
      </view>
    </block>
    <view wx:if="{{!posts.length}}" class="empty-tip">
      还没有内容，先记录一下今天吃了什么吧~
    </view>
  </view>

  <!-- 底部可爱背景装饰区域 -->
  <view class="bottom-decor">
    <!-- 小猫贴纸 -->
    <view class="cat-sticker">🐱</view>
    <view class="cat-bubble">吃饱才有力气学习~</view>

    <!-- 漂浮爱心 -->
    <view class="heart heart1">💗</view>
    <view class="heart heart2">💖</view>
    <view class="heart heart3">💞</view>
  </view>
</view>
