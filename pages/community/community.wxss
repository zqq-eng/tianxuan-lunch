/* ========== 社区页 · 粉色体系 + 可爱下半部分背景 ========== */
page {
  background: linear-gradient(180deg, #ffeaf4 0%, #fff6fb 45%, #ffeef7 100%);
}

.container {
  position: relative;
  min-height: 100vh;
  padding: 32rpx 24rpx 40rpx;
  box-sizing: border-box;
  overflow: hidden;
}

/* 背景气泡 */
.container::before,
.container::after {
  content: "";
  position: absolute;
  border-radius: 50%;
  opacity: 0.35;
  z-index: 0;
}

.container::before {
  width: 220rpx;
  height: 220rpx;
  background: #ffd1e8;
  top: 40rpx;
  right: -80rpx;
}

.container::after {
  width: 260rpx;
  height: 260rpx;
  background: #ffe2f0;
  bottom: 120rpx;
  left: -60rpx;
}

/* 顶部漂浮的小表情图标 */
.floating-icon-comm {
  position: absolute;
  z-index: 1;
  font-size: 38rpx;
  opacity: 0.55;
  animation: commFloatUp 11s linear infinite;
}

.fi1 {
  left: 12%;
  top: 52%;
  animation-delay: 0s;
}

.fi2 {
  right: 10%;
  top: 26%;
  animation-delay: 3s;
}

@keyframes commFloatUp {
  0% {
    transform: translateY(36rpx);
    opacity: 0;
  }
  20% {
    opacity: 0.6;
  }
  80% {
    transform: translateY(-120rpx);
    opacity: 0.6;
  }
  100% {
    transform: translateY(-160rpx);
    opacity: 0;
  }
}

/* ========== 卡片基础（带轻微渐变边框） ========== */
.card {
  position: relative;
  z-index: 2;
  margin-bottom: 24rpx;
  border-radius: 24rpx;
  padding: 22rpx 20rpx 20rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.96);
  backdrop-filter: blur(8rpx);
}

.card::before {
  content: "";
  position: absolute;
  inset: -5rpx;
  border-radius: inherit;
  background: conic-gradient(
    from 120deg,
    #ffb3d1,
    #ffe29f,
    #ffd8f0,
    #ff9ac6
  );
  z-index: -2;
  animation: commBorderRotate 9s linear infinite;
}

.card::after {
  content: "";
  position: absolute;
  inset: 4rpx;
  border-radius: inherit;
  background:
    radial-gradient(circle at 0% 0%, rgba(255, 255, 255, 0.96) 0, rgba(255, 255, 255, 0) 55%),
    radial-gradient(circle at 100% 100%, rgba(255, 214, 240, 0.94) 0, rgba(255, 214, 240, 0) 70%),
    rgba(255, 255, 255, 0.98);
  z-index: -1;
}

@keyframes commBorderRotate {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

/* 第一张卡稍微浮动（发帖卡） */
.card:first-child {
  animation: commCardFloat 4.2s ease-in-out infinite;
}

@keyframes commCardFloat {
  0% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-4rpx);
  }
  100% {
    transform: translateY(0);
  }
}

/* ========== 标题 ========== */
.title {
  font-size: 32rpx;
  font-weight: 700;
  color: #ff4f7d;
  margin-bottom: 16rpx;
}

/* ========== 发布区域 ========== */
.textarea {
  width: 100%;
  min-height: 160rpx;
  border-radius: 20rpx;
  padding: 16rpx 18rpx;
  background: #fdf7fb;
  font-size: 26rpx;
  box-sizing: border-box;
  color: #555;
}

/* 发布按钮 */
.button-primary {
  margin-top: 16rpx;
  width: 100%;
  padding: 16rpx 0;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #ff8fb8, #ff6b99);
  color: #fff;
  font-size: 28rpx;
  box-shadow: 0 8rpx 16rpx rgba(255, 122, 178, 0.35);
}

.button-primary:active {
  transform: scale(0.96);
}

/* 提示文字 */
.tip {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #aaa;
}

/* ========== 我的记录列表 ========== */
.post {
  margin-top: 12rpx;
  padding: 12rpx 14rpx;
  border-radius: 18rpx;
  background: #fff7fb;
}

.post-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 4rpx;
}

.time {
  font-size: 22rpx;
  color: #999;
}

.body {
  font-size: 26rpx;
  color: #555;
  line-height: 1.6;
}

/* 没有内容时的提示 */
.empty-tip {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #bbb;
}

/* ========== 下半部分可爱背景区域 ========== */
.bottom-decor {
  position: relative;
  margin-top: 10rpx;
  height: 220rpx;
  border-radius: 40rpx 40rpx 0 0;
  overflow: hidden;
  z-index: 1;
  background:
    radial-gradient(circle at 10% 0%, #ffe3f0 0, transparent 55%),
    radial-gradient(circle at 90% 0%, #ffeefc 0, transparent 55%),
    linear-gradient(180deg, #ffe6f4 0, #ffdff0 40%, #ffd2eb 100%);
  box-shadow: 0 -8rpx 18rpx rgba(255, 158, 188, 0.32);
}

/* 类似藤曼的小弧线装饰（左右各一条） */
.bottom-decor::before,
.bottom-decor::after {
  content: "";
  position: absolute;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  border: 6rpx dotted rgba(255, 255, 255, 0.65);
  bottom: -120rpx;
}

.bottom-decor::before {
  left: -40rpx;
}

.bottom-decor::after {
  right: -40rpx;
}

/* 小猫贴纸 */
.cat-sticker {
  position: absolute;
  left: 46rpx;
  bottom: 46rpx;
  font-size: 68rpx;
  text-shadow: 0 6rpx 14rpx rgba(255, 122, 178, 0.55);
  animation: catFloat 3.6s ease-in-out infinite;
}

@keyframes catFloat {
  0% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-10rpx);
  }
  100% {
    transform: translateY(0);
  }
}

/* 小猫旁边的气泡提示 */
.cat-bubble {
  position: absolute;
  left: 132rpx;
  bottom: 82rpx;
  max-width: 360rpx;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  font-size: 24rpx;
  color: #ff6b9c;
  box-shadow: 0 8rpx 16rpx rgba(255, 158, 188, 0.3);
}

/* 尾巴 */
.cat-bubble::before {
  content: "";
  position: absolute;
  left: -18rpx;
  bottom: 6rpx;
  width: 26rpx;
  height: 26rpx;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 50%;
}

/* 漂浮爱心们 */
.heart {
  position: absolute;
  bottom: 16rpx;
  font-size: 40rpx;
  opacity: 0.7;
  animation: heartFloatUp 6s ease-in-out infinite;
}

.heart1 {
  left: 60%;
  animation-delay: 0s;
}

.heart2 {
  left: 72%;
  animation-delay: 1.2s;
}

.heart3 {
  left: 84%;
  animation-delay: 2.4s;
}

@keyframes heartFloatUp {
  0% {
    transform: translateY(0) scale(0.9);
    opacity: 0;
  }
  10% {
    opacity: 0.8;
  }
  60% {
    transform: translateY(-100rpx) scale(1.05);
    opacity: 0.8;
  }
  100% {
    transform: translateY(-160rpx) scale(1.1);
    opacity: 0;
  }
}
