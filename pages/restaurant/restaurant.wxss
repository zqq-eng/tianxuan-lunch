page {
  background: #ffe6f2;
}

.container {
  padding: 24rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: #ff6b6b;
}

.add-btn {
  margin-bottom: 20rpx;
  background: #ff9ac6;
  color: #ffffff;
  border-radius: 999rpx;
}

.empty {
  margin-top: 80rpx;
  text-align: center;
  color: #999;
  font-size: 26rpx;
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.04);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-main {
  flex: 1;
}

.r-name {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.r-sub {
  font-size: 24rpx;
  color: #999999;
}

.card-actions button {
  margin-left: 10rpx;
}
