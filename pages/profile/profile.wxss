/* ==================== 页面背景 ==================== */
page {
  background: linear-gradient(180deg, #ffeaf4 0%, #fff7fd 45%, #ffe4f3 100%);
  font-family: "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei",
    system-ui, -apple-system, sans-serif;
}

.profile-page {
  position: relative;
  min-height: 100vh;
  padding: 30rpx 24rpx 80rpx;
  box-sizing: border-box;
  overflow: visible;
}

/* ==================== 顶部装饰（小猫 + 云朵 + 粒子） ==================== */
.float-decor {
  position: fixed;
  inset: 0;
  z-index: 9999;     /* 最高层 */
  pointer-events: none; /* 不挡按钮点击 */
}

/* 漂浮猫 */
.float-cat {
  position: absolute;
  font-size: 60rpx;
  opacity: 0.9;
  animation: catFloat 6s ease-in-out infinite;
  text-shadow: 0 8rpx 16rpx rgba(255, 140, 170, 0.28);
}

.float-cat.cat-1 {
  top: 80rpx;
  left: 40rpx;
}
.float-cat.cat-2 {
  top: 320rpx;
  right: 40rpx;
  animation-delay: 1s;
}

/* 云朵漂浮 */
.float-cloud {
  position: absolute;
  width: 180rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #eea0ee 0%, #b6be84 100%);
  border-radius: 80rpx;
  opacity: 0.55;
  box-shadow: 0 10rpx 20rpx rgba(255, 150, 220, 0.3);
  animation: cloudMove 12s linear infinite;
}

.float-cloud.c1 {
  bottom: 260rpx;
  left: 40rpx;
}
.float-cloud.c2 {
  bottom: 160rpx;
  right: 60rpx;
  animation-delay: 3s;
}

/* 爱心粒子 */
.heart-field {
  position: absolute;
  inset: 0;
}

.heart-dot {
  position: absolute;
  font-size: 26rpx;
  color: #ff9ac6;
  opacity: 0.45;
  animation: heartRise 7s linear infinite;
}

.h1 { left: 15%; top: 75%; animation-delay: 0s; }
.h2 { left: 35%; top: 82%; animation-delay: 1.2s; }
.h3 { left: 55%; top: 70%; animation-delay: 2.4s; }
.h4 { left: 75%; top: 88%; animation-delay: 3.6s; }
.h5 { left: 50%; top: 60%; animation-delay: 4.8s; }


/* ==================== 用户卡片 ==================== */
.card {
  position: relative;
  z-index: 10;
  margin-bottom: 32rpx;
  padding: 32rpx 26rpx 30rpx;
  border-radius: 28rpx;
  overflow: hidden;
}

/* 外层渐变猫爪边框 */
.card::before {
  content: "";
  position: absolute;
  inset: -6rpx;
  border-radius: inherit;
  background: conic-gradient(
    from 150deg,
    #ffc1da,
    #ffe2f1,
    #ffd6f3,
    #ffb5d0,
    #ffc1da
  );
  z-index: -2;
  animation: borderSpin 12s linear infinite;
}

/* 内层柔光背景 + 细藤条纹 */
.card::after {
  content: "";
  position: absolute;
  inset: 4rpx;
  border-radius: inherit;
  background:
    repeating-linear-gradient(
      135deg,
      rgba(180, 230, 180, 0.45) 0,
      rgba(180, 230, 180, 0.45) 2rpx,
      transparent 2rpx,
      transparent 12rpx
    ),
    radial-gradient(circle at 0% 0%, rgba(255,255,255,0.98) 0%, transparent 60%),
    radial-gradient(circle at 100% 100%, rgba(255,220,240,0.98) 0%, transparent 70%),
    #ffffff;
  background-blend-mode: soft-light, normal, normal, normal;
  z-index: -1;
}

/* 用户名 + 头像大字母 */
.user-initial {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #ffbcd7, #ff94b9);
  color: #fff;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 50rpx;
  font-weight: 700;
  box-shadow: 0 10rpx 18rpx rgba(255, 120, 170, 0.35);
  margin: 0 auto 16rpx;
}

/* 登出按钮 */
.logout-btn {
  margin-top: 18rpx;
  width: 70%;
  margin-left: auto;
  margin-right: auto;
  background: linear-gradient(90deg, #ffa6c7, #ff82a9);
  color: #fff;
  border-radius: 999rpx;
  padding: 16rpx 0;
  font-size: 28rpx;
  box-shadow: 0 10rpx 16rpx rgba(255, 120, 160, 0.35);
}

/* 猫爪点击闪动 */
.logout-btn:active {
  transform: scale(0.97);
}
.logout-btn:active::after {
  content: "🐾";
  position: absolute;
  right: 60rpx;
  top: 50%;
  transform: translateY(-50%) scale(1.4);
  opacity: 0.8;
  animation: pawFlash 0.45s ease-out;
}


/* ==================== 表单区域 ==================== */
.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #ff6fa8;
  margin-bottom: 22rpx;
  display: flex;
  align-items: center;
}
.section-title::before {
  content: "🐾";
  font-size: 32rpx;
  margin-right: 8rpx;
}

/* 输入框标签 */
.label {
  font-size: 26rpx;
  color: #ff7da8;
  margin-bottom: 10rpx;
  padding-left: 10rpx;
}

/* 输入框（重点：加高！不再遮挡文字） */
.input {
  width: 100%;
  padding: 24rpx 30rpx;   /* 之前太小导致文字顶到边框 */
  font-size: 30rpx;
  line-height: 40rpx;
  border-radius: 22rpx;
  background: #ffffff;
  border: 2rpx solid #ffd8e8;
  box-shadow: 0 8rpx 14rpx rgba(255, 170, 200, 0.28);
  box-sizing: border-box;
}

/* 选择器 */
.picker {
  width: 100%;
  padding: 22rpx 28rpx;
  font-size: 30rpx;
  background: #fff;
  border-radius: 22rpx;
  border: 2rpx solid #ffd8e8;
  box-shadow: 0 8rpx 14rpx rgba(255, 170, 200, 0.28);
}

/* 标签按钮 */
.tags {
  display: flex;
  flex-wrap: wrap;
  margin-top: 16rpx;
}

.tag {
  padding: 10rpx 22rpx;
  margin: 8rpx;
  border-radius: 999rpx;
  background: #ffe9f3;
  color: #ff7da8;
  font-size: 24rpx;
  box-shadow: 0 6rpx 10rpx rgba(255, 160, 190, 0.25);
}

/* 保存按钮 */
.save-btn {
  margin-top: 26rpx;
  width: 100%;
  padding: 20rpx 0;
  font-size: 32rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #ff8fb8, #ff6b99);
  color: #fff;
  box-shadow: 0 10rpx 18rpx rgba(255, 120, 160, 0.35);
}

/* 猫爪点击动画 */
.save-btn:active {
  transform: scale(0.97);
}
.save-btn:active::after {
  content: "🐾";
  position: absolute;
  right: 50rpx;
  top: 50%;
  transform: translateY(-50%) scale(1.35);
  opacity: 0.8;
  animation: pawFlash 0.45s ease-out;
}


/* ==================== 动画 ==================== */
@keyframes borderSpin {
  from { transform: rotate(0); }
  to { transform: rotate(360deg); }
}

@keyframes catFloat {
  0% { transform: translateY(0); }
  50% { transform: translateY(-12rpx); }
  100% { transform: translateY(0); }
}

@keyframes cloudMove {
  0% { transform: translateX(0); }
  50% { transform: translateX(-20rpx); }
  100% { transform: translateX(0); }
}

@keyframes heartRise {
  0% { transform: translateY(0) scale(0.6); opacity: 0.45; }
  100% { transform: translateY(-100rpx) scale(1.3); opacity: 0; }
}

@keyframes pawFlash {
  0% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.6; transform: scale(1.4); }
  100% { opacity: 1; transform: scale(1); }
}
/* ===== 饮食偏好 · 标签区域美化 ===== */

.field-row-like {
  margin-top: 24rpx;
}

/* 左侧标题保持对齐即可 */
.field-row-like .field-label {
  font-size: 26rpx;
  color: #ff6b9c;
  font-weight: 600;
  margin-bottom: 10rpx;
}

/* 标签容器：多行换行、留间距 */
.tag-list {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 12rpx 16rpx;
}

/* 单个标签胶囊 */
.tag-pill {
  padding: 8rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 6rpx 12rpx rgba(255, 180, 210, 0.35);
  border: 1rpx solid rgba(255, 182, 214, 0.7);
  min-width: 140rpx;
  text-align: center;
  box-sizing: border-box;
}

/* 标签文字：可爱粉色 */
.tag-text {
  font-size: 24rpx;
  color: #ff6b96;
}

/* 可编辑标签：淡淡虚线边框，显得是“可点的” */
.tag-editable {
  border-style: dashed;
}

/* “＋ 自定义” 按钮：用渐变高亮一点 */
.tag-add {
  background: linear-gradient(90deg, #ffe3f5, #ffd1f0);
  border-color: transparent;
}

.tag-add .tag-text {
  color: #ff4f88;
  font-weight: 600;
}

/* 点击时有轻微缩放的猫爪感 */
.tag-pill:active {
  transform: scale(0.96);
  box-shadow: 0 3rpx 8rpx rgba(255, 140, 190, 0.4);
}
