.container {
  padding: 30rpx 20rpx 60rpx;
}
.top-card {
  margin-bottom: 24rpx;
}
.user-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}
.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff9a9e, #fecf6a);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 700;
  margin-right: 24rpx;
}
.info .name {
  font-size: 32rpx;
  font-weight: 600;
}
.info .sub {
  margin-top: 4rpx;
  font-size: 24rpx;
  color: #888888;
}
.title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
}
.picker {
  padding: 16rpx 24rpx;
  border-radius: 999px;
  background: #f5f5f5;
  margin-bottom: 20rpx;
  font-size: 26rpx;
}
.input {
  background: #f9f9f9;
  border-radius: 999px;
  padding: 20rpx 32rpx;
  margin-bottom: 24rpx;
  font-size: 28rpx;
}
.tag-row {
  flex-wrap: wrap;
}
.tag {
  margin: 8rpx 12rpx 0 0;
}
