page {
  background: #ffe6f2;
}

.container {
  padding: 32rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
  color: #ff6b6b;
}

.sub {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 24rpx;
}

.block {
  margin-bottom: 20rpx;
}

.label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 4rpx;
}

.text {
  font-size: 28rpx;
  color: #333;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  background: #fff;
  box-shadow: 0 8rpx 16rpx rgba(0,0,0,0.04);
  border: 1rpx solid #ffe0ef;
}
