page {
  background: linear-gradient(135deg, #ffe5f0, #fff5d7);
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", "PingFang SC", "Microsoft YaHei", sans-serif;
}
.button-primary {
  background: linear-gradient(135deg, #ff9a9e, #fecf6a);
  color: #ffffff;
  border-radius: 999px;
  padding: 16rpx 32rpx;
  font-size: 30rpx;
  box-shadow: 0 8rpx 16rpx rgba(0,0,0,0.12);
}
.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 24rpx;
  box-shadow: 0 12rpx 24rpx rgba(0,0,0,0.06);
}
.tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 999px;
  background: rgba(255, 155, 113, 0.15);
  color: #ff6b6b;
  font-size: 22rpx;
  margin-right: 12rpx;
}
